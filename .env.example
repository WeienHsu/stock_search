# -----------------------------------------------------------------------------
# Stock Search / Stock Intelligence environment template
# Copy this file to `.env` and fill in only the services you use.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Backend for user-scoped app data such as preferences, watchlist, risk settings,
# notification settings, and user secrets.
# Options:
#   json   - local JSON files under data/users; simple local development default.
#   sqlite - data/users.db; recommended for multi-user/local SaaS style usage.
STORAGE_BACKEND=sqlite


# -----------------------------------------------------------------------------
# App secrets / encrypted per-user secrets
# -----------------------------------------------------------------------------
# Required for storing per-user API keys and notification credentials in Settings.
# Also required when FINNHUB_KEY_MODE=per_user.
# Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this stable. Changing it makes previously saved encrypted secrets unreadable.
APP_SECRET_KEY=


# -----------------------------------------------------------------------------
# Finnhub news / sentiment
# -----------------------------------------------------------------------------
# Finnhub API key for Dashboard news/sentiment when FINNHUB_KEY_MODE=global.
FINNHUB_API_KEY=your_key_here

# Finnhub key mode:
#   global   - one shared key from FINNHUB_API_KEY.
#   per_user - each user sets their own key in Settings; requires APP_SECRET_KEY.
FINNHUB_KEY_MODE=global


# -----------------------------------------------------------------------------
# AI signal explanation / digest providers
# -----------------------------------------------------------------------------
# Provider order. Only providers with configured keys are used.
# Supported provider ids:
#   anthropic_haiku, anthropic_sonnet, gemini_flash, openai
AI_PROVIDER_ORDER=anthropic_haiku,gemini_flash,openai,anthropic_sonnet

# System-level AI keys. Users can also set personal keys in Settings when
# APP_SECRET_KEY is configured; personal keys take precedence.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional model overrides.
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
ANTHROPIC_SONNET_MODEL=claude-3-5-sonnet-latest
GEMINI_FLASH_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini


# -----------------------------------------------------------------------------
# Taiwan market data
# -----------------------------------------------------------------------------
# Optional FinMind token for Phase A chip/fundamental data probes and future
# FinMind-backed data adapters. Tokenless access may work but can be throttled.
FINMIND_API_TOKEN=


# -----------------------------------------------------------------------------
# External sentiment sources
# -----------------------------------------------------------------------------
# Optional Reddit OAuth credentials. When all three are set and PRAW is installed,
# Reddit sentiment uses OAuth; otherwise it falls back to public web JSON.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_USER_AGENT=stock-search/1.0

# Optional Stocktwits API bearer token. Without this, Stocktwits still uses the
# public symbol stream endpoint when available.
STOCKTWITS_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------------
# For Docker compose, keep this 0 because the worker service owns scheduled jobs.
# For single-process local testing only, set to 1 before `streamlit run app.py`.
ENABLE_STREAMLIT_SCHEDULER=0


# -----------------------------------------------------------------------------
# Notification channels
# -----------------------------------------------------------------------------
# Email SMTP, Telegram Bot, and LINE Messaging API credentials are configured in
# the app Settings page and encrypted with APP_SECRET_KEY. They are not read from
# `.env` in the current codebase.

# Set to 1 in local smoke tests to record notifications as JSONL instead of
# sending email / Telegram / LINE / inbox messages.
NOTIFICATION_DRY_RUN=0
NOTIFICATION_DRY_RUN_PATH=.cache/dry_run_notifications.jsonl
