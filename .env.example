FINNHUB_API_KEY=your_key_here

# Backend: json (local file, default) | sqlite (multi-user SaaS)
STORAGE_BACKEND=sqlite

# Finnhub key mode:
#   global   — one key in FINNHUB_API_KEY above, shared by all users (default, backward-compatible)
#   per_user — each user sets their own key in the Settings page (requires APP_SECRET_KEY)
FINNHUB_KEY_MODE=global

# Required when FINNHUB_KEY_MODE=per_user — used to encrypt stored API keys.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=

# Scheduler:
#   Docker compose runs a separate worker service, so keep this 0 there.
#   For single-process local testing only, set to 1 before streamlit run app.py.
ENABLE_STREAMLIT_SCHEDULER=0
